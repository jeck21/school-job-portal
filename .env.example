NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Site URL for auth email redirects (e.g., https://school-job-portal.vercel.app or http://localhost:3003)
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# Scraper: service role key for direct DB writes (bypasses RLS)
# Get from: Supabase Dashboard -> Project Settings -> API -> service_role key (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
